PORT=3000
NODE_ENV=development

# PostgreSQL connection (Render: use the "Internal Database URL")
DATABASE_URL=postgres://user:password@localhost:5432/fps_arena

# Session + JWT secrets (generate long random strings in production)
SESSION_SECRET=change_me_please_long_random_string
JWT_SECRET=change_me_too_long_random_string

# Play-money credits given to new accounts
STARTING_CREDITS=1000

# House fee on shooter pot payouts (percentage, 0-100). 5 = 5%
HOUSE_FEE_PERCENT=5

# Comma-separated list of admin user IDs (UUIDs after first run)
ADMIN_USER_IDS=

# CORS origin for production (e.g. https://your-app.onrender.com).
# Leave empty in development for same-origin only.
CORS_ORIGIN=
