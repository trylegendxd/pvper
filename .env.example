PORT=3000
NODE_ENV=development

# PostgreSQL connection (Render: use the "Internal Database URL")
DATABASE_URL=postgres://user:password@localhost:5432/fps_arena

# Session + JWT secrets (generate long random strings in production)
SESSION_SECRET=change_me_please_long_random_string
JWT_SECRET=change_me_too_long_random_string

# Play-money credits given to new accounts
STARTING_CREDITS=1000

# House fee on shooter pot payouts (percentage, 0-100). 5 = 5%
HOUSE_FEE_PERCENT=5

# Comma-separated list of admin user IDs (UUIDs after first run)
ADMIN_USER_IDS=

# CORS origin for production (e.g. https://your-app.onrender.com).
# Leave empty in development for same-origin only.
CORS_ORIGIN=

# ── Crypto (USDC on Base) — OFF by default ──────────────────────────────────
# Leave CRYPTO_ENABLED=false to keep the platform play-money only. The crypto
# wallet UI hides itself and all /api/crypto endpoints return crypto_disabled.
# Use Base Sepolia (testnet) first. Switch to mainnet ONLY after reviewing the
# legal/compliance notes in the README — see the values below the testnet set.
CRYPTO_ENABLED=false
CRYPTO_NETWORK=base-sepolia
BASE_RPC_URL=
BASE_CHAIN_ID=84532
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_DECIMALS=6
# The platform treasury wallet. TREASURY_PRIVATE_KEY is server-only and is
# NEVER exposed to the frontend. Fund it with USDC to pay out withdrawals.
TREASURY_ADDRESS=
TREASURY_PRIVATE_KEY=
USDC_TO_CREDITS_RATE=100
MIN_DEPOSIT_USDC=1
MIN_WITHDRAW_USDC=1
DEPOSIT_CONFIRMATIONS=3
WITHDRAWAL_CONFIRMATIONS=3
WITHDRAWALS_AUTO_ENABLED=false
WITHDRAWALS_MANUAL_REVIEW=true

# ── For Base mainnet (real funds) set instead: ──────────────────────────────
# CRYPTO_NETWORK=base
# BASE_CHAIN_ID=8453
# USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
